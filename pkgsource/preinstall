#!/bin/bash

# Unload the LaunchDaemon if it is currently loaded, so the new version
# can be put in place cleanly before postinstall reloads it.

DAEMON_LABEL="gov.nasa.cset.psm-monitor"
PLIST="/Library/LaunchDaemons/${DAEMON_LABEL}.plist"

if launchctl list | grep -q "$DAEMON_LABEL"; then
    echo "Unloading ${DAEMON_LABEL}..."
    launchctl unload "$PLIST" 2>/dev/null
fi

exit 0
